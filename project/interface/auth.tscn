size_flags_horizontal = 3
theme_override_colors/font_color = Color(0.309804, 0.372549, 0.266667, 0.9)
theme_override_font_sizes/font_size = 15
text = "Se guarda en este dispositivo y se actualiza al volver a Mi progreso."
autowrap_mode = 3

[node name="RegisterButton" type="Button" parent="Card/MarginContainer/Content/FooterPanel/MarginContainer/Footer"]
custom_minimum_size = Vector2(248, 58)
layout_mode = 2
theme_override_colors/font_color = Color(1, 1, 1, 1)
theme_override_font_sizes/font_size = 20
theme_override_styles/normal = SubResource("StyleBoxFlat_primary_button")
theme_override_styles/hover = SubResource("StyleBoxFlat_primary_button_hover")
theme_override_styles/pressed = SubResource("StyleBoxFlat_primary_button_hover")
theme_override_styles/focus = SubResource("StyleBoxFlat_primary_button_hover")
text = "Guardar perfil"

[node name="AvatarDialog" type="FileDialog" parent="."]
access = 2
file_mode = 0
title = "Seleccionar foto de perfil"
filters = PackedStringArray("*.png ; PNG", "*.jpg ; JPG", "*.jpeg ; JPEG", "*.webp ; WEBP")

[connection signal="pressed" from="Card/MarginContainer/Content/MainRow/FormPanel/MarginContainer/FormContent/AvatarRow/ChooseAvatarButton" to="." method="_on_choose_avatar_button_pressed"]
[connection signal="pressed" from="Card/MarginContainer/Content/MainRow/FormPanel/MarginContainer/FormContent/AvatarRow/ClearAvatarButton" to="." method="_on_clear_avatar_button_pressed"]
[connection signal="pressed" from="Card/MarginContainer/Content/FooterPanel/MarginContainer/Footer/RegisterButton" to="." method="_on_register_button_pressed"]
[connection signal="pressed" from="BackButton" to="." method="_on_back_button_pressed"]
[connection signal="file_selected" from="AvatarDialog" to="." method="_on_avatar_dialog_file_selected"]