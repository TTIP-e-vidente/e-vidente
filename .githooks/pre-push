#!/bin/sh

set -eu

. "$(dirname "$0")/lib/common.sh"

cd_repo_root

if [ "${SKIP_EVIDENTE_HOOKS:-0}" = "1" ] || [ "${SKIP_GODOT_PREPUSH:-0}" = "1" ]; then
	exit 0
fi

needs_validation=0

if git rev-parse --abbrev-ref --symbolic-full-name @{upstream} >/dev/null 2>&1; then
	changed_files="$(git diff --name-only @{upstream}..HEAD)"
	if printf '%s\n' "$changed_files" | grep -Eq '^(project/|\.github/workflows/ci\.yml|\.githooks/|scripts/)'; then
		needs_validation=1
	fi
else
	needs_validation=1
fi

if [ "$needs_validation" -eq 0 ]; then
	exit 0
fi

if ! godot_cmd="$(resolve_godot_cmd)"; then
	print_warn "No se encontro Godot CLI en PATH. Se saltea la validacion local y queda cubierta por CI."
	exit 0
fi

echo "Ejecutando validacion local antes de push..."
. scripts/run-godot-validation.sh
run_godot_validation "$godot_cmd"