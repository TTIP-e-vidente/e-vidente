#!/bin/sh

set -eu

. "$(dirname "$0")/lib/common.sh"

if [ "${SKIP_EVIDENTE_HOOKS:-0}" = "1" ]; then
	exit 0
fi

message_file="$1"
first_line="$(sed -n '1p' "$message_file" | tr -d '\r')"

if [ -z "$first_line" ]; then
	print_error "El mensaje de commit no puede estar vacio."
	exit 1
fi

case "$first_line" in
	Merge\ *|Revert\ *|fixup\!*|squash\!*)
		exit 0
		;;
esac

if printf '%s\n' "$first_line" | grep -Eq '^(feat|fix|docs|chore|refactor|test|ci|build|perf|style)(\([a-z0-9._/-]+\))?: .{5,72}$'; then
	exit 0
fi

cat >&2 <<'EOF'
Aviso: mensaje de commit fuera del formato sugerido.

Formato esperado:
  tipo(scope): resumen

Tipos permitidos:
  feat, fix, docs, chore, refactor, test, ci, build, perf, style

Ejemplos validos:
  feat(auth): guarda sesion local
  fix(save-manager): corrige carga del ultimo usuario
  docs(git-hooks): explica setup local
EOF

exit 0