#!/bin/sh

set -eu

if [ "${SKIP_EVIDENTE_HOOKS:-}" = "1" ] || [ "${ALLOW_GODOT_ENGINE_CHANGE:-}" = "1" ]; then
	exit 0
fi

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR)
if [ -z "$STAGED_FILES" ]; then
	exit 0
fi

ENGINE_MANAGED_FILES=$(printf '%s\n' "$STAGED_FILES" | grep -E '^(project/project\.godot|project/.*\.import|project/\.godot/)' || true)
if [ -z "$ENGINE_MANAGED_FILES" ]; then
	exit 0
fi

echo "Se detectaron archivos administrados por Godot en el commit:" >&2
printf '%s\n' "$ENGINE_MANAGED_FILES" >&2
echo >&2
echo "Este repo esta alineado a Godot 4.2; abrirlo con otra version suele reescribir project.godot y .import sin cambios funcionales reales." >&2
echo "Si el cambio es intencional, repite el commit con ALLOW_GODOT_ENGINE_CHANGE=1." >&2
exit 1